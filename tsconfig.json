{
	"include": [
		"src/**/*.ts"
	],
	"compilerOptions": {
		"module": "Preserve",
		"moduleResolution": "bundler",
		"target": "ES2024",
		"types": [
			"node",
			"vscode"
		],
		"lib": [
			"ES2024"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"outDir": "out",
		"skipLibCheck": true
	}
}