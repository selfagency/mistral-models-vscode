{
	"name": "mistral-ai-copilot-chat",
	"publisher": "OEvortex",
	"displayName": "Mistral AI for GitHub Copilot Chat",
	"description": "Integrate Mistral AI models including Devstral, Mistral Large, and Mistral Medium into GitHub Copilot Chat",
	"icon": "logo.png",
	"license": "MIT",
	"preview": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/OEvortex/vscode-mistral-copilot-chat"
	},
	"version": "0.1.2",
	"engines": {
		"vscode": "^1.104.0"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages"
	],
	"keywords": [
		"mistral",
		"ai",
		"copilot",
		"chat",
		"devstral",
		"coding",
		"code assistant"
	],
	"activationEvents": [
		"onLanguageModelChatProvider:mistral"
	],
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "mistral",
				"displayName": "Mistral AI",
				"managementCommand": "mistral-chat.manageApiKey"
			}
		],
		"commands": [
			{
				"command": "mistral-chat.manageApiKey",
				"title": "Mistral: Manage API Key"
			}
		]
	},
	"main": "./dist/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run lint && node esbuild.js --production",
		"check-types": "tsc --noEmit",
		"deploy": "vsce publish",
		"prerelease": "vsce publish --pre-release",
		"lint": "eslint src"
	},
	"dependencies": {
		"@mistralai/mistralai": "^1.3.6",
		"tiktoken": "^1.0.22"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/vscode": "^1.103.0",
		"@vscode/dts": "^0.4.1",
		"esbuild": "^0.25.8",
		"eslint": "^9.13.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}