{
	"name": "mistral-ai-copilot-chat",
	"displayName": "Mistral AI for GitHub Copilot Chat",
	"version": "0.1.3",
	"description": "Access Mistral AI models within GitHub Copilot Chat",
	"categories": [
		"AI",
		"Chat"
	],
	"keywords": [
		"mistral",
		"ai",
		"copilot",
		"chat",
		"devstral",
		"coding",
		"code assistant"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/selfagency/mistral-models-vscode.git"
	},
	"license": "MIT",
	"qna": "marketplace",
	"author": {
		"name": "Daniel Sieradski",
		"email": "daniel@self.agency",
		"url": "https://self.agency"
	},
	"publisher": "selfagency",
	"main": "./dist/extension.js",
	"scripts": {
		"check-types": "tsc --noEmit",
		"compile": "pnpm run check-types && pnpm run lint && tsup",
		"deploy": "vsce publish",
		"format": "oxfmt 'src/**/*.ts' --write",
		"lint": "oxlint 'src/**/*.ts'",
		"lint:fix": "oxlint 'src/**/*.ts' --fix",
		"package": "pnpm run check-types && pnpm run lint && NODE_ENV=production tsup",
		"prerelease": "vsce publish --pre-release",
		"vscode:prepublish": "pnpm run package",
		"watch:build": "tsup --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"watch": "pnpm-run-all -p watch:*",
		"prepare": "husky"
	},
	"contributes": {
		"commands": [
			{
				"command": "mistral-chat.manageApiKey",
				"title": "Mistral: Manage API Key"
			}
		],
		"languageModelChatProviders": [
			{
				"vendor": "mistral",
				"displayName": "Mistral AI",
				"configuration": {
					"managementCommand": "mistral-chat.manageApiKey"
				}
			}
		]
	},
	"activationEvents": [
		"onLanguageModelChatProvider:mistral"
	],
	"dependencies": {
		"@mistralai/mistralai": "^1.14.1",
		"tiktoken": "^1.0.22"
	},
	"devDependencies": {
		"@types/node": "^25.3.2",
		"@types/vscode": "^1.109.0",
		"@vscode/dts": "^0.4.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"npm-run-all": "^4.1.5",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0",
		"oxlint-tsgolint": "^0.15.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"engines": {
		"vscode": "^1.104.0"
	},
	"icon": "logo.png"
}
